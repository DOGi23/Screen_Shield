<Window x:Class="ScreenShield.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenShield Toast" 
        Height="70" 
        Width="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <Storyboard x:Key="FadeInAndOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.0" To="0.95" Duration="0:0:0.35"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.95" To="0.0" Duration="0:0:0.35"
                             BeginTime="0:0:1.6"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="ToastBorder" 
            Background="#121216" 
            BorderBrush="#2D323E" 
            BorderThickness="1.5" 
            CornerRadius="6" 
            Padding="14,10,14,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock x:Name="ToastIcon" 
                       Text="🛡️" 
                       FontSize="26" 
                       VerticalAlignment="Center" 
                       Margin="0,0,12,0"/>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="ToastTitle" 
                           Text="ЗАЩИТА АКТИВИРОВАНА" 
                           FontWeight="Bold" 
                           FontSize="11.5" 
                           Foreground="#50C878"/>
                <TextBlock x:Name="ToastMessage" 
                           Text="Окна и рабочий стол скрыты от захвата." 
                           FontSize="10.5" 
                           Foreground="#808B9B"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
