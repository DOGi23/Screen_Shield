<Window x:Class="ScreenShield.FloatingPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Floating Panel" Height="450" Width="400"
        Background="#1E1E24" Foreground="#D0D6E2"
        WindowStartupLocation="CenterOwner"
        BorderThickness="1" BorderBrush="#3F475B"
        AllowsTransparency="False"
        WindowStyle="None"
        Closing="Window_Closing">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Flat Button Style -->
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2F3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3F475B"/>
            <Setter Property="Padding" Value="12,6,12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                CornerRadius="3" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A4052"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#505A73"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E222D"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#2A2F3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Flat Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Background" Value="#1D2029"/>
            <Setter Property="BorderBrush" Value="#2D3242"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Dark Header Bar -->
        <Border Grid.Row="0" Background="#121216" BorderThickness="0,0,0,1" BorderBrush="#2D323E">
            <Grid Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Draggable Title Area -->
                <TextBlock x:Name="TitleText" Text="Floating Panel" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>

                <!-- Dock Back Button -->
                <Button Grid.Column="1" 
                        x:Name="DockButton"
                        Content="↙ Вернуть" 
                        Height="20" 
                        Padding="8,0,8,0"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="DockButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        VerticalAlignment="Center"/>

                <!-- Close Button -->
                <Button Grid.Column="2" 
                        Content="×" 
                        Width="20" 
                        Height="20" 
                        Background="Transparent"
                        Foreground="#E05050"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="14"
                        Cursor="Hand"
                        Click="CloseButton_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Dynamic Content Presenter -->
        <ContentPresenter x:Name="ContentArea" Grid.Row="1" Margin="10"/>
    </Grid>
</Window>
