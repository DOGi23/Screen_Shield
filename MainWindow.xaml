<Window x:Class="ScreenShield.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenShield" 
        Height="650" 
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E24"
        Foreground="#D0D6E2"
        FontFamily="Segoe UI, Tahoma"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Icon="icon.png">

    <Window.Resources>
        <!-- Flat Minimal ScrollViewer Style -->
        <Style x:Key="FlatScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                                       Value="{TemplateBinding VerticalOffset}" 
                                       Maximum="{TemplateBinding ScrollableHeight}" 
                                       ViewportSize="{TemplateBinding ViewportHeight}" 
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       HorizontalAlignment="Right" 
                                       Width="8" 
                                       Background="#18181C"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clean Flat Card Style -->
        <Style x:Key="FlatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#121216"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2D323E"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Link Style for Select All / Deselect All -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#808B9B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}" TextDecorations="None" x:Name="Txt"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat Minimalist CheckBox Style -->
        <Style x:Key="FlatCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D0D6E2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Flat Button Style -->
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2F3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3F475B"/>
            <Setter Property="Padding" Value="12,6,12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                CornerRadius="3" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3A4052"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#505A73"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1E222D"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#2A2F3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Flat Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Background" Value="#1D2029"/>
            <Setter Property="BorderBrush" Value="#2D3242"/>
        </Style>

        <!-- Small Icon Button Style (for detach) -->
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="6,2,6,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Flat Minimalist ComboBox Style -->
        <Style x:Key="FlatComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#1A1A20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3D4454"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0,8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Background Border -->
                            <Border x:Name="BgBorder" 
                                    Grid.ColumnSpan="2" 
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="3"/>
                            
                            <!-- Selected Content Display Area -->
                            <ContentPresenter x:Name="ContentSite" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                              Margin="{TemplateBinding Padding}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              IsHitTestVisible="False"/>
                            
                            <!-- Arrow Button Icon -->
                            <Grid Grid.Column="1" Margin="0,0,4,0" IsHitTestVisible="False">
                                <Path x:Name="Arrow" 
                                      Data="M 0 0 L 3.5 4 L 7 0 Z" 
                                      Fill="#808B9B" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Grid>
                            
                            <!-- Toggle Button invisible overlay to handle clicks -->
                            <ToggleButton x:Name="ToggleButton" 
                                          Grid.ColumnSpan="2" 
                                          Background="Transparent" 
                                          BorderThickness="0" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <!-- Pop-up dropdown list container -->
                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" 
                                      SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}" 
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" 
                                            Background="#121216" 
                                            BorderBrush="#2D323E" 
                                            BorderThickness="1" 
                                            CornerRadius="4"
                                            Margin="0,2,0,4">
                                        <ScrollViewer SnapsToDevicePixels="True" Style="{StaticResource FlatScrollViewer}">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#505A73"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#6C80A4"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BgBorder" Property="Background" Value="#15151A"/>
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#252A36"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#505A73"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- HEADER SECTION -->
        <Border Grid.Row="0" Background="#121216" BorderThickness="0,0,0,1" BorderBrush="#2D323E">
            <Grid Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand and subtitle -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="icon.png" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SCREENSHIELD" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Height="14" Width="1" Background="#3D4454" Margin="12,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Движок скрытия окон и рабочего стола от захвата экрана" FontSize="11" Foreground="#808B9B" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Admin Status Badge -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="AdminBadge" 
                            Background="#2E1C22" 
                            BorderBrush="#A0404C" 
                            BorderThickness="1" 
                            CornerRadius="2" 
                            Padding="8,2,8,2" 
                            Margin="0,0,12,0" 
                            VerticalAlignment="Center">
                        <TextBlock Text="АДМИНИСТРАТОР" FontSize="9" FontWeight="Bold" Foreground="#F07080"/>
                    </Border>
                    <TextBlock x:Name="GlobalStatusText" Text="Защита: Активна" FontSize="11.5" Foreground="#50C878" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button x:Name="GlobalProtectionButton"
                            Content="Выключить защиту"
                            Style="{StaticResource FlatButtonStyle}"
                            Background="#A0404C"
                            BorderBrush="#C05060"
                            Height="24"
                            Padding="10,0,10,0"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Click="GlobalProtectionButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN DASHBOARD CONTENT -->
        <Grid Grid.Row="1" Margin="20,15,20,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: Desktop Shielding, Custom Wallpaper & Specific Icons -->
            <ScrollViewer Grid.Column="0" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled" 
                          Style="{StaticResource FlatScrollViewer}" 
                          Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Row 0: Profiles Card -->
                        <RowDefinition Height="Auto"/> <!-- Row 1: Hotkey Settings Card -->
                        <RowDefinition Height="Auto"/> <!-- Row 2: Desktop Shield Card -->
                        <RowDefinition Height="Auto"/> <!-- Row 3: Checklist & AutoShield Grid -->
                    </Grid.RowDefinitions>

                <!-- CARD 0: Profiles Management -->
                <Border Grid.Row="0" Style="{StaticResource FlatCardStyle}" Padding="15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="ТЕКУЩИЙ ПРОФИЛЬ НАСТРОЕК" FontSize="11" FontWeight="Bold" Foreground="#808B9B"/>
                            <ComboBox x:Name="ProfileComboBox" 
                                      Style="{StaticResource FlatComboBoxStyle}"
                                      Margin="0,6,8,0" 
                                      SelectionChanged="ProfileComboBox_SelectionChanged">
                                <!-- Explicit DataTemplate to force selected item text to remain white -->
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#121216"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding" Value="6,4,6,4"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2A2F3D"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3A4052"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </StackPanel>

                        <Button Grid.Column="1" 
                                Content="+" 
                                Width="32" 
                                Height="28" 
                                Margin="0,17,4,0" 
                                Style="{StaticResource FlatButtonStyle}"
                                ToolTip="Создать новый профиль"
                                Click="AddProfile_Click"
                                VerticalAlignment="Bottom"/>

                        <Button x:Name="RenameProfileButton"
                                Grid.Column="2" 
                                Content="✎" 
                                Width="32" 
                                Height="28" 
                                Margin="0,17,4,0" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Переименовать текущий профиль"
                                Click="RenameProfile_Click"
                                VerticalAlignment="Bottom"/>

                        <Button x:Name="DeleteProfileButton"
                                Grid.Column="3" 
                                Content="×" 
                                Width="32" 
                                Height="28" 
                                Margin="0,17,0,0" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Удалить текущий профиль"
                                Click="DeleteProfile_Click"
                                VerticalAlignment="Bottom"
                                Foreground="#E05050"/>
                    </Grid>
                </Border>

                <!-- CARD 0.5: Global Hotkey Settings & Boot Autostart -->
                <Border Grid.Row="1" Style="{StaticResource FlatCardStyle}" Padding="15">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="ГОРЯЧАЯ КЛАВИША БЫСТРОГО ВКЛЮЧЕНИЯ" FontSize="11" FontWeight="Bold" Foreground="#808B9B"/>
                                <TextBlock Text="Быстрое включение/выключение защиты из любого окна" FontSize="10" Foreground="#606B7B" Margin="0,2,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="HotkeyRecorderButton" 
                                            Content="Ctrl + Shift + S" 
                                            Width="180" 
                                            Height="28" 
                                            Style="{StaticResource FlatButtonStyle}"
                                            Background="#1A1A20"
                                            BorderBrush="#3D4454"
                                            Click="HotkeyRecorderButton_Click"
                                            PreviewKeyDown="HotkeyRecorderButton_PreviewKeyDown"/>
                                    <TextBlock Text="нажмите для изменения" FontSize="9.5" Foreground="#505A6A" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <CheckBox x:Name="HotkeyEnableToggle" 
                                      Grid.Column="1" 
                                      Style="{StaticResource FlatCheckBoxStyle}" 
                                      Content="Активна"
                                      Checked="HotkeyEnableToggle_Checked" 
                                      Unchecked="HotkeyEnableToggle_Unchecked"
                                      VerticalAlignment="Center"/>
                        </Grid>
                        
                        <Border Height="1" Background="#232733" Margin="0,10,0,10"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="АВТОЗАПУСК ПРИ СТАРТЕ WINDOWS" FontSize="11" FontWeight="Bold" Foreground="#808B9B"/>
                                <TextBlock Text="Запуск ScreenShield свернутым в трей при включении ПК" FontSize="10" Foreground="#606B7B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="AutostartToggle" 
                                      Grid.Column="1" 
                                      Style="{StaticResource FlatCheckBoxStyle}" 
                                      Content="Выключен"
                                      Checked="AutostartToggle_Checked" 
                                      Unchecked="AutostartToggle_Unchecked"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#232733" Margin="0,10,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="СКРЫТИЕ ИЗ ПАНЕЛИ ЗАДАЧ" FontSize="11" FontWeight="Bold" Foreground="#808B9B"/>
                                <TextBlock Text="Скрывать кнопки защищенных программ с панели задач Windows" FontSize="10" Foreground="#606B7B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="HideTaskbarToggle" 
                                      Grid.Column="1" 
                                      Style="{StaticResource FlatCheckBoxStyle}" 
                                      Content="Выключено"
                                      Checked="HideTaskbarToggle_Checked" 
                                      Unchecked="HideTaskbarToggle_Unchecked"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CARD 1: Desktop Shield & Wallpaper -->
                <Border Style="{StaticResource FlatCardStyle}" Padding="15" Grid.Row="2">
                    <ContentControl x:Name="DesktopShieldParent">
                        <Grid x:Name="DesktopShieldContent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Title, toggle & detach button -->
                            <Grid Grid.Row="0">
                                <StackPanel>
                                    <TextBlock Text="ЗАЩИТА РАБОЧЕГО СТОЛА" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="Скрытие оригинальных обоев и ярлыков рабочего стола" FontSize="10" Foreground="#808B9B" Margin="0,2,0,0"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="↗ Открепить" 
                                            Style="{StaticResource IconButtonStyle}" 
                                            Margin="0,0,10,0"
                                            Click="DetachPanel_Click" 
                                            Tag="desktop"/>
                                    
                                    <CheckBox x:Name="DesktopShieldToggle" 
                                              Style="{StaticResource FlatCheckBoxStyle}" 
                                              Content="Включить"
                                              Checked="DesktopShieldToggle_Checked" 
                                              Unchecked="DesktopShieldToggle_Unchecked"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Height="1" Background="#232733" Margin="0,12,0,12"/>

                            <!-- Custom Capture Wallpaper Setup (with Drag & Drop support) -->
                            <StackPanel Grid.Row="2" 
                                        AllowDrop="True" 
                                        DragEnter="WallpaperPanel_DragEnter" 
                                        DragLeave="WallpaperPanel_DragLeave" 
                                        Drop="WallpaperPanel_Drop" 
                                        x:Name="WallpaperDropPanel" 
                                        Background="Transparent"
                                        Margin="0,0,0,2">
                                <TextBlock Text="Обои для записи (то, что увидит OBS):" FontSize="11" Foreground="#A0AAB8" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox x:Name="CustomWallpaperPathBox" 
                                             Height="26" 
                                             Background="#1A1A20" 
                                             Foreground="White" 
                                             BorderThickness="1" 
                                             BorderBrush="#3D4454" 
                                             Padding="6,0,6,0" 
                                             VerticalContentAlignment="Center" 
                                             FontSize="11"
                                             IsReadOnly="True"/>
                                    
                                    <Button Grid.Column="1" 
                                            Content="..." 
                                            Height="26" 
                                            Margin="4,0,0,0" 
                                            Style="{StaticResource FlatButtonStyle}"
                                            Padding="0"
                                            Click="BrowseWallpaper_Click"/>

                                    <Button Grid.Column="2" 
                                            Content="Сбросить" 
                                            Height="26" 
                                            Margin="4,0,0,0" 
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="0"
                                            Click="ResetWallpaper_Click"/>
                                </Grid>

                                <!-- OBS Helper Banner -->
                                <Border Margin="0,10,0,0" 
                                        Background="#122536" 
                                        BorderThickness="1" 
                                        BorderBrush="#1B3A54" 
                                        CornerRadius="4" 
                                        Padding="10,8,10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="ℹ️" FontSize="14" VerticalAlignment="Top" Margin="0,0,8,0"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Настройка OBS Studio:" FontWeight="Bold" FontSize="11" Foreground="#92C4EE" Margin="0,0,0,3"/>
                                            <TextBlock Text="Если в OBS вместо обоев виден черный или серый экран: зайдите в свойства источника «Захват экрана» в OBS и ОБЯЗАТЕЛЬНО переключите «Метод захвата» на «Windows 10 (1903 и выше)» (WGC)!" 
                                                       FontSize="10" 
                                                       Foreground="#A2B9CE" 
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ContentControl>
                </Border>

                <!-- CARD 2: Specific Icons Selection & Auto-Shield List -->
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <!-- Icons Checklist -->
                    <Border Style="{StaticResource FlatCardStyle}" Padding="15" Grid.Row="0">
                        <ContentControl x:Name="IconsChecklistParent">
                            <Grid x:Name="IconsChecklistContent">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <StackPanel>
                                        <TextBlock Text="ЯРЛЫКИ НА РАБОЧЕМ СТОЛЕ" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Выберите иконки, которые нужно ПОКАЗАТЬ на вашем экране" FontSize="10" Foreground="#808B9B" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="↗ Открепить" 
                                                Style="{StaticResource IconButtonStyle}" 
                                                Margin="0,0,10,0"
                                                Click="DetachPanel_Click" 
                                                Tag="icons"/>
                                        
                                        <CheckBox x:Name="IconShieldToggle" 
                                                  Style="{StaticResource FlatCheckBoxStyle}" 
                                                  Content="Включить"
                                                  Checked="IconShieldToggle_Checked" 
                                                  Unchecked="IconShieldToggle_Unchecked"/>
                                    </StackPanel>
                                </Grid>

                                 <StackPanel Grid.Row="1">
                                     <Border Height="1" Background="#232733" Margin="0,10,0,6"/>
                                     <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                         <Button Content="Выбрать все" Style="{StaticResource LinkButtonStyle}" Click="SelectAllIcons_Click"/>
                                         <TextBlock Text="|" Foreground="#40FFFFFF" Margin="6,0,6,0" VerticalAlignment="Center"/>
                                         <Button Content="Снять все" Style="{StaticResource LinkButtonStyle}" Click="UnselectAllIcons_Click"/>
                                     </StackPanel>
                                 </StackPanel>

                                <!-- Checked Items List -->
                                <ListBox x:Name="IconsCheckListBox" 
                                         Grid.Row="2" 
                                         Height="220"
                                         Background="Transparent" 
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                 <CheckBox IsChecked="{Binding IsChecked}" 
                                                           Content="{Binding Name}" 
                                                           Style="{StaticResource FlatCheckBoxStyle}"
                                                           Click="IconCheckbox_Click"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </ContentControl>
                    </Border>

                    <Grid Grid.Row="1" Height="2"/>

                    <!-- Auto-Shield List -->
                    <Border Style="{StaticResource FlatCardStyle}" Padding="15" Grid.Row="2">
                        <ContentControl x:Name="AutoShieldParent">
                            <Grid x:Name="AutoShieldContent">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <StackPanel>
                                        <TextBlock Text="АВТОМАТИЧЕСКИ СКРЫВАЕМЫЕ ПРОЦЕССЫ" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="Скрытие указанных приложений сразу при их запуске" FontSize="10" Foreground="#808B9B" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    
                                    <Button Content="↗ Открепить" 
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource IconButtonStyle}" 
                                            Click="DetachPanel_Click" 
                                            Tag="autoshield"/>
                                </Grid>

                                <!-- Process Input Bar -->
                                <Grid Grid.Row="1" Margin="0,10,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox x:Name="AutoShieldInput" 
                                             Height="28" 
                                             Background="#1A1A20" 
                                             Foreground="White" 
                                             BorderThickness="1" 
                                             BorderBrush="#3D4454" 
                                             Padding="8,0,8,0" 
                                             VerticalContentAlignment="Center" 
                                             FontSize="12"
                                             Text="telegram"/>
                                    
                                    <Button Grid.Column="1" 
                                            Content="+" 
                                            Width="30" 
                                            Height="28" 
                                            Margin="4,0,0,0" 
                                            Style="{StaticResource FlatButtonStyle}"
                                            Click="AddAutoShield_Click"/>

                                    <Button Grid.Column="2" 
                                            Content="Обзор EXE..." 
                                            Height="28" 
                                            Margin="4,0,0,0" 
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BrowseExe_Click"/>
                                </Grid>

                                <!-- List of autoshields -->
                                <ListBox x:Name="AutoShieldListBox" 
                                         Grid.Row="2" 
                                         Height="160"
                                         Background="Transparent" 
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#16161C" BorderThickness="1" BorderBrush="#262A34" Padding="8,4,8,4" Margin="0,0,0,4" CornerRadius="2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" 
                                                            Content="×" 
                                                            Foreground="#E05050" 
                                                            Background="Transparent" 
                                                            BorderThickness="0" 
                                                            FontWeight="Bold"
                                                            FontSize="14"
                                                            Padding="4,0,4,0"
                                                            Cursor="Hand"
                                                            Click="RemoveAutoShield_Click" 
                                                            Tag="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </ContentControl>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

            <!-- RIGHT COLUMN: Active Windows Capture Shield -->
            <Border Style="{StaticResource FlatCardStyle}" Padding="15" Grid.Column="1">
                <ContentControl x:Name="WindowShieldParent">
                    <Grid x:Name="WindowShieldContent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Section Title & Buttons -->
                        <Grid Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="АКТИВНЫЕ ОКНА В СИСТЕМЕ" FontSize="13" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Скрытие выбранных приложений от стрима (OBS, Discord, Zoom)" FontSize="10" Foreground="#808B9B" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="↗ Открепить" 
                                        Style="{StaticResource IconButtonStyle}" 
                                        Margin="0,0,10,0"
                                        Click="DetachPanel_Click" 
                                        Tag="windows"/>
                                
                                <Button Width="100" 
                                        Height="28" 
                                        Style="{StaticResource FlatButtonStyle}"
                                        Content="Обновить" 
                                        Click="RefreshWindows_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Search Filter Bar -->
                        <Border Grid.Row="1" Background="#1A1A20" BorderThickness="1" BorderBrush="#3D4454" CornerRadius="3" Height="30" Margin="0,12,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                      Fill="#606B7B" 
                                      Width="14" 
                                      Height="14" 
                                      Stretch="Uniform" 
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                                
                                <TextBox x:Name="SearchBox" 
                                         Grid.Column="1" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="White" 
                                         Padding="4,0,8,0" 
                                         VerticalContentAlignment="Center" 
                                         FontSize="12"
                                         TextChanged="SearchBox_TextChanged"
                                         GotFocus="SearchBox_GotFocus"
                                         LostFocus="SearchBox_LostFocus"
                                         Text="Поиск приложений..."/>
                            </Grid>
                        </Border>

                        <!-- Windows List with Application Icons -->
                        <DockPanel Grid.Row="2">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="Скрыть все окна" Style="{StaticResource LinkButtonStyle}" Click="SelectAllWindows_Click"/>
                                <TextBlock Text="|" Foreground="#40FFFFFF" Margin="6,0,6,0" VerticalAlignment="Center"/>
                                <Button Content="Показать все окна" Style="{StaticResource LinkButtonStyle}" Click="UnselectAllWindows_Click"/>
                            </StackPanel>

                            <ListBox x:Name="WindowsListBox" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#16161C" BorderThickness="1" BorderBrush="#262A34" Padding="10" Margin="0,0,0,6" CornerRadius="3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- App Native Icon -->
                                            <Image Grid.Column="0" 
                                                   Source="{Binding Icon}" 
                                                   Width="24" 
                                                   Height="24" 
                                                   Margin="0,0,10,0" 
                                                   VerticalAlignment="Center"/>

                                            <!-- Name & Metadata -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding ProcessName}" Foreground="White" FontWeight="Bold" FontSize="12.5"/>
                                                    
                                                    <!-- Simple Flat Badges -->
                                                    <TextBlock Text=" [АДМИН]" Foreground="#E05050" FontWeight="Bold" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"
                                                               Visibility="{Binding IsElevated, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    
                                                    <TextBlock Text=" [СКРЫТО]" Foreground="#50C878" FontWeight="Bold" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"
                                                               Visibility="{Binding IsShielded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding WindowTitle}" Foreground="#808B9B" FontSize="10.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Shield Checkbox -->
                                            <CheckBox Grid.Column="2" 
                                                      Style="{StaticResource FlatCheckBoxStyle}"
                                                      Content="Скрыть"
                                                      IsChecked="{Binding IsShielded, Mode=OneWay}"
                                                      Checked="WindowShieldToggle_Checked"
                                                      Unchecked="WindowShieldToggle_Unchecked"
                                                      Tag="{Binding Hwnd}"
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
                </ContentControl>
            </Border>
        </Grid>

        <!-- FOOTER SECTION -->
        <Border Grid.Row="2" Background="#121216" BorderThickness="0,1,0,0" BorderBrush="#2D323E">
            <Grid Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="" FontSize="10" Foreground="#606B7B" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Скрытых окон: " FontSize="10.5" Foreground="#606B7B"/>
                    <TextBlock x:Name="ActiveShieldCountText" Text="0" FontSize="10.5" FontWeight="Bold" Foreground="#FFFFFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MODAL OVERLAY FOR CREATING NEW PROFILE -->
        <Grid x:Name="ModalOverlay" 
              Grid.RowSpan="3" 
              Background="#A0000000" 
              Visibility="Collapsed" 
              Panel.ZIndex="1000">
            
            <Border Width="340" 
                    Height="160" 
                    Background="#1E1E24" 
                    BorderThickness="1" 
                    BorderBrush="#3F475B" 
                    CornerRadius="4" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="СОЗДАНИЕ НОВОГО ПРОФИЛЯ" FontSize="12.5" FontWeight="Bold" Foreground="White"/>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Введите название профиля (например: Стрим или Работа):" FontSize="10.5" Foreground="#808B9B" Margin="0,0,0,6"/>
                        <TextBox x:Name="NewProfileNameBox" 
                                 Height="28" 
                                 Background="#1A1A20" 
                                 Foreground="White" 
                                 BorderThickness="1" 
                                 BorderBrush="#3D4454" 
                                 Padding="6,0,6,0" 
                                 VerticalContentAlignment="Center" 
                                 FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Создать" 
                                Height="28" 
                                Width="85" 
                                Style="{StaticResource FlatButtonStyle}"
                                Click="ModalCreateProfile_Click"
                                Margin="0,0,8,0"/>
                        
                        <Button Content="Отмена" 
                                Height="28" 
                                Width="85" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ModalCancelProfile_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- MODAL OVERLAY FOR RENAMING PROFILE -->
        <Grid x:Name="ModalRenameOverlay" 
              Grid.RowSpan="3" 
              Background="#A0000000" 
              Visibility="Collapsed" 
              Panel.ZIndex="1000">
            
            <Border Width="340" 
                    Height="160" 
                    Background="#1E1E24" 
                    BorderThickness="1" 
                    BorderBrush="#3F475B" 
                    CornerRadius="4" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ПЕРЕИМЕНОВАНИЕ ПРОФИЛЯ" FontSize="12.5" FontWeight="Bold" Foreground="White"/>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="Введите новое название для активного профиля:" FontSize="10.5" Foreground="#808B9B" Margin="0,0,0,6"/>
                        <TextBox x:Name="RenameProfileNameBox" 
                                 Height="28" 
                                 Background="#1A1A20" 
                                 Foreground="White" 
                                 BorderThickness="1" 
                                 BorderBrush="#3D4454" 
                                 Padding="6,0,6,0" 
                                 VerticalContentAlignment="Center" 
                                 FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Сохранить" 
                                Height="28" 
                                Width="85" 
                                Style="{StaticResource FlatButtonStyle}"
                                Click="ModalRenameProfile_Save_Click"
                                Margin="0,0,8,0"/>
                        
                        <Button Content="Отмена" 
                                Height="28" 
                                Width="85" 
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ModalRenameProfile_Cancel_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
